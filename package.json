{
  "name": "@shmaplex/xplant-sdk",
  "version": "0.1.0",
  "description": "Official JavaScript/TypeScript SDK for the xPlant external API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --max-warnings=0",
    "prepublishOnly": "npm run build && npm run typecheck && npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "xplant",
    "lab",
    "tissue-culture",
    "iot",
    "sdk",
    "shmaplex",
    "plant-science",
    "laboratory",
    "sensor"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/shmaplex/xplant-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/shmaplex/xplant-sdk/issues"
  },
  "homepage": "https://github.com/shmaplex/xplant-sdk#readme",
  "engines": {
    "node": ">=18"
  }
}
